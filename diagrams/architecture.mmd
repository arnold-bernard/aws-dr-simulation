%% Architecture diagram for aws-dr-simulation
%% Services: VPC, Public/Private Subnets, ALB, ECS, ECR, RDS (Multi-AZ), IAM, CloudWatch, Security Groups, Terraform, Scripts, Runbooks

flowchart LR
  %% Actors
  Internet["Internet<br/>Users / Testers"]

  %% Infrastructure boundary
  subgraph VPC[VPC]
    direction TB
    subgraph Public[Public Subnets]
      ALB["ALB<br/>Application Load Balancer"]
    end

    subgraph Private[Private Subnets]
      ECSCluster["ECS Cluster<br/>Service + Tasks"]
      ECSTask["ECS Task<br/>Flask App"]
      ECR["ECR<br/>Container Registry"]
      RDSPrimary["RDS Postgres<br/>Primary (Multi-AZ)"]
      RDSStandby["RDS Postgres<br/>Standby (Multi-AZ)"]
    end

    NAT["NAT Gateway"]
  end

  %% Observability & IAM
  CloudWatch["CloudWatch<br/>Metrics & Logs"]
  IAM["IAM Roles & Policies"]

  %% IaC and artifacts
  Terraform["Terraform<br/>Infrastructure as Code"]
  Scripts["scripts/<br/>simulate-az-failure.sh<br/>measure-rto.sh"]
  Runbooks["runbooks/<br/>initial-assumptions.md"]

  %% Security
  SGs["Security Groups<br/>ALB-SG, ECS-SG, RDS-SG"]

  %% Connections
  Internet -->|HTTP/HTTPS| ALB
  ALB -->|Targets / Health checks| ECSTask
  ECSCluster --> ECSTask
  ECSTask -->|pull image| ECR
  ECSTask -->|connects (5432)| RDSPrimary
  ECSTask -->|connects (read replica / failover)| RDSStandby
  RDSPrimary ---|replication / failover| RDSStandby

  ALB --> CloudWatch
  ECSTask --> CloudWatch
  RDSPrimary --> CloudWatch

  Terraform --> ALB
  Terraform --> ECSCluster
  Terraform --> ECR
  Terraform --> RDSPrimary
  Terraform --> IAM
  Terraform --> SGs

  Scripts --> ECSCluster
  Scripts --> RDSPrimary
  Runbooks --> Scripts

  SGs --> ALB
  SGs --> ECSTask
  SGs --> RDSPrimary

  IAM --> ECSTask
  IAM --> Terraform

  %% Notes
  subgraph Notes[Notes]
    direction TB
    Note1["- ALB in public subnets<br/>- ECS & RDS in private subnets"]
    Note2["- RDS configured Multi-AZ (Primary + Standby).<br/>- Use Secrets Manager for credentials in production."]
  end

  Notes --- Terraform
